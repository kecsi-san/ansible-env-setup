---
# Infrastructure-specific values for this deployment.
# Copy this file to secrets.yml and fill in your values.
# secrets.yml is gitignored and will never be committed.

domain_name: "yourdomain.local"

upstream_dns_servers:
  - "192.168.x.x"

ansible_ssh_user: your_ssh_user
admin_user: your_admin_user

kube_vip_address: "192.168.x.x"
kube_vip_interface: "eth0"

# Short SSH hostname of a control plane node (used by setup_kube-extra to copy kubeconfig)
kube_control_plane_host: "your-control-plane-node"
