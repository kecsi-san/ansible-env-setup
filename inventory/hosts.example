# Copy this file to inventory/hosts and fill in your own values.
# inventory/hosts is gitignored and will never be committed.

node1 ansible_host=192.168.1.10 ip=192.168.1.10
node2 ansible_host=192.168.1.11 ip=192.168.1.11
node3 ansible_host=192.168.1.12 ip=192.168.1.12
node4 ansible_host=192.168.1.13 ip=192.168.1.13
api.k8s ansible_host=192.168.1.100 ip=192.168.1.100

[local]
127.0.0.1  ansible_connection=local


[kube]
node1  # describe your hardware here, e.g. 32g RAM, i5-9500T 6 cores
node2
node3
node4

[kube_control_plane]
node1
node2
node3

[etcd]
node1
node2
node3

[kube_node]
node1
node2
node3
node4

[calico_rr]

[k8s_cluster:children]
kube_control_plane
kube_node
calico_rr
