# =============================================================================
# Ansible
# =============================================================================
.ansible                          # Ansible local cache directory
*.retry                           # Failed playbook host lists
**/vagrant_ansible_inventory      # Auto-generated Vagrant inventory
roles/**/molecule/**/__pycache__/ # Molecule test bytecode cache

# Galaxy-installed roles and collections — not vendored, install with:
#   ansible-galaxy install -r requirements.yml
roles/markosamuli.linuxbrew/
ansible_collections

# =============================================================================
# Kubernetes / Kubespray
# =============================================================================
kubernetes_sigs-kubespray*tar.gz  # Downloaded Kubespray collection archive

# =============================================================================
# Vagrant
# =============================================================================
.vagrant                          # Vagrant VM state directory
vagrant/                          # Local Vagrant workspace
plugins/mitogen                   # Mitogen Ansible connection plugin

# =============================================================================
# Terraform / IaC
# =============================================================================
.terraform/                       # Terraform provider cache
.terraform.lock.hcl               # Terraform provider lock file (project-specific)
*.tfstate                         # Terraform state — contains sensitive infra data
*.tfstate*backup                  # Terraform state backups
*.lock.hcl                        # Generic HCL lock files
contrib/offline/*.tar.gz          # Offline package archives
contrib/terraform/aws/credentials.tfvars  # AWS credentials — never commit

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
.python-version                   # pyenv local version pin

# Packaging artifacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# pip logs
pip-log.txt
pip-delete-this-directory.txt

# Test and coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Virtual environments
.venv/
venv/
env/
ENV/

# =============================================================================
# IDE / Editor
# =============================================================================
.idea                             # JetBrains IDE project files
.vscode                           # VS Code workspace settings
*.iml                             # IntelliJ module files
**/*.sw[pon]                      # Vim swap files
*~                                # Backup files (emacs, gedit, etc.)
*.bak                             # Generic backup files

# =============================================================================
# OS
# =============================================================================
.DS_Store                         # macOS Finder metadata

# =============================================================================
# Secrets and sensitive inventory
# =============================================================================

# Real host IPs and hostnames — copy inventory/hosts.example and fill in your values
inventory/hosts

# Infrastructure secrets (domain, DNS, SSH user, kube-vip) — copy secrets.yml.example
inventory/group_vars/all/secrets.yml

# Credentials directories and dynamic SSH config generated by Kubespray
credentials/
/ssh-bastion.conf

# =============================================================================
# Project / misc
# =============================================================================
temp
tmp.md
scripts/tmp/
*.log
*/logs/*
todo.md*                          # Local task notes

# =============================================================================
# Claude Code
# =============================================================================
.claude                           # Local Claude Code settings (machine-specific)
