# =============================================================================
# Ansible
# =============================================================================
# Ansible local cache directory
.ansible
# Failed playbook host lists
*.retry
# Auto-generated Vagrant inventory
**/vagrant_ansible_inventory
# Molecule test bytecode cache
roles/**/molecule/**/__pycache__/
# backup file
inventory/group_vars/local.yml.bak

# Galaxy-installed roles and collections — not vendored, install with:
#   ansible-galaxy install -r requirements.yml
roles/markosamuli.linuxbrew/
ansible_collections

# =============================================================================
# Kubernetes / Kubespray
# =============================================================================
# Downloaded Kubespray collection archive
kubernetes_sigs-kubespray*tar.gz

# =============================================================================
# Vagrant
# =============================================================================
# Vagrant VM state directory
.vagrant
# Local Vagrant workspace
vagrant/
# Mitogen Ansible connection plugin
plugins/mitogen

# =============================================================================
# Terraform / IaC
# =============================================================================
# Terraform provider cache
.terraform/
# Terraform provider lock file (project-specific)
.terraform.lock.hcl
# Terraform state — contains sensitive infra data
*.tfstate
# Terraform state backups
*.tfstate*backup
# Generic HCL lock files
*.lock.hcl
# Offline package archives
contrib/offline/*.tar.gz
# AWS credentials — never commit
contrib/terraform/aws/credentials.tfvars

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
# pyenv local version pin
.python-version

# Packaging artifacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# pip logs
pip-log.txt
pip-delete-this-directory.txt

# Test and coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Virtual environments
.venv/
venv/
env/
ENV/

# =============================================================================
# IDE / Editor
# =============================================================================
# JetBrains IDE project files
.idea
# VS Code workspace settings
.vscode
# IntelliJ module files
*.iml
# Vim swap files
**/*.sw[pon]
# Backup files (emacs, gedit, etc.)
*~
# Generic backup files
*.bak

# =============================================================================
# OS
# =============================================================================
# macOS Finder metadata
.DS_Store

# =============================================================================
# Secrets and sensitive inventory
# =============================================================================

# Real host IPs and hostnames — copy inventory/hosts.example and fill in your values
inventory/hosts

# Infrastructure secrets (domain, DNS, SSH user, kube-vip) — copy secrets.yml.example
inventory/group_vars/all/secrets.yml

# Credentials directories and dynamic SSH config generated by Kubespray
credentials/
/ssh-bastion.conf

# =============================================================================
# Project / misc
# =============================================================================
temp
tmp.md
scripts/tmp/
*.log
*/logs/*
# Local task notes
todo.md*

# =============================================================================
# Claude Code
# =============================================================================
# Local Claude Code settings (machine-specific)
.claude
